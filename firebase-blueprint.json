{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile containing company and representative information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "company"] },
        "companyName": { "type": "string" },
        "country": { "type": "string" },
        "address": { "type": "string" },
        "website": { "type": "string" },
        "representativeName": { "type": "string" },
        "position": { "type": "string" },
        "phone": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "companyName", "representativeName"]
    },
    "Product": {
      "title": "Product",
      "description": "Product in the catalog.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "isFeatured": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "category", "imageUrl"]
    },
    "LOI": {
      "title": "Letter of Intent",
      "description": "Purchase request from a company.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "companyId": { "type": "string" },
        "companyName": { "type": "string" },
        "product": { "type": "string" },
        "quantity": { "type": "string" },
        "budget": { "type": "string" },
        "incoterm": { "type": "string" },
        "port": { "type": "string" },
        "deadline": { "type": "string" },
        "additionalInfo": { "type": "string" },
        "status": { "type": "string", "enum": ["searching", "offer_sent", "negotiating", "provider_identified", "finalized"] },
        "adminResponse": {
          "type": "object",
          "properties": {
            "proposedQuantity": { "type": "string" },
            "incoterm": { "type": "string" },
            "location": { "type": "string" },
            "price": { "type": "string" },
            "deliveryTime": { "type": "string" },
            "attachments": { "type": "array", "items": { "type": "string" } },
            "updatedAt": { "type": "string", "format": "date-time" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["companyId", "product", "quantity", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product catalog"
    },
    "/lois/{loiId}": {
      "schema": "LOI",
      "description": "Letters of Intent"
    }
  }
}
